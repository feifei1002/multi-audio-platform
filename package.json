{
  "name": "multi-audio-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start:server": "cd server && (gradlew bootRun || ./gradlew bootRun)",
    "start:client": "cd client && npx expo start",
    "dev": "npx concurrently \"npm run start:server\" \"npm run start:client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}